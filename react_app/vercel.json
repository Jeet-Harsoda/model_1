{
  "version": 2,
  "builds": [
    {
      "src": "back_end/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "front_end/dist/**"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "back_end/index.js"
    }
  ]
}